---
const title = "Digital Impact GPT";
---

<html lang="en">
<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{title}</title>

<style>

body{
background:#0b0f19;
color:white;
font-family:Arial;
margin:0;
}

header{
padding:40px;
display:flex;
justify-content:space-between;
align-items:center;
}

.logo{
font-size:24px;
font-weight:bold;
}

.hero{
text-align:center;
padding:120px 20px;
}

.hero h1{
font-size:64px;
margin-bottom:20px;
}

.hero p{
font-size:22px;
opacity:0.7;
}

button{
background:#4f46e5;
color:white;
border:none;
padding:16px 32px;
font-size:18px;
border-radius:10px;
cursor:pointer;
margin-top:30px;
}

.section{
padding:100px 20px;
text-align:center;
}

.cards{
display:flex;
gap:30px;
justify-content:center;
flex-wrap:wrap;
margin-top:40px;
}

.card{
background:#141a2a;
padding:40px;
border-radius:12px;
width:260px;
}

footer{
padding:40px;
text-align:center;
opacity:0.5;
}

</style>

</head>

<body>

<header>

<div class="logo">Digital Impact GPT</div>

</header>

<section class="hero">

<h1>Enterprise AI Platform</h1>

<p>AION CORE – Autonomous AI Infrastructure</p>

<button>Request Demo</button>

</section>

<section class="section">

<h2>Platform Modules</h2>

<div class="cards">

<div class="card">
<h3>AI Core</h3>
<p>Neural decision engine</p>
</div>

<div class="card">
<h3>Trading AI</h3>
<p>Autonomous market analysis</p>
</div>

<div class="card">
<h3>Enterprise Brain</h3>
<p>Company-scale decision system</p>
</div>

</div>

</section>

<footer>

Digital Impact GPT © 2026

</footer>

</body>
</html>
